# ============================================================
# Minecraft SMP — Variabile de Mediu (Template)
# INSTRUCȚIUNI: Copiază acest fișier ca .env și completează valorile
#   cp .env.example .env
#   nano .env
# SECURITATE: .env este în .gitignore — NICIODATĂ commit cu secrete!
# ============================================================

# ── Server ───────────────────────────────────────────────────

# Memoria heap JVM — 4G pentru 10-15 jucători, 6G pentru 20-30
MEMORY=4G

# Numele serverului afișat în Minecraft server list (§a = culoare verde)
MOTD=§aSMP Românesc | Vanilla cu prieteni

# Numărul maxim de jucători conectați simultan
MAX_PLAYERS=30

# Dificultate: peaceful / easy / normal / hard
DIFFICULTY=normal

# Mod de joc implicit la prima conectare: survival / creative / adventure
GAMEMODE=survival

# Autentificare Mojang — OBLIGATORIU true în producție
# false permite conturi piratate (NON-RECOMANDAT)
ONLINE_MODE=true

# ── RCON ─────────────────────────────────────────────────────
# Parola RCON — generează cu: openssl rand -base64 32
# Minim 24 de caractere alfanumerice
RCON_PASSWORD=PLACEHOLDER_RCON_PASSWORD_MINIM_24_CARACTERE

# Port RCON — intern Docker, NICIODATĂ expus în UFW
RCON_PORT=25575

# ── Timezone ─────────────────────────────────────────────────
# Fusul orar pentru log-uri și cron-uri
TZ=Europe/Bucharest

# ── Discord (DiscordSRV) ──────────────────────────────────────
# Token bot Discord — discord.com/developers/applications → Bot → Token
DISCORD_BOT_TOKEN=PLACEHOLDER_DISCORD_BOT_TOKEN

# ID server Discord (Guild ID) — activează Developer Mode → right-click server
DISCORD_GUILD_ID=PLACEHOLDER_DISCORD_GUILD_ID

# ID canal #chat-minecraft — right-click canal → Copy ID
DISCORD_CHANNEL_ID_CHAT=PLACEHOLDER_CHANNEL_ID_CHAT

# ID canal #decese — pentru mesajele de moarte
DISCORD_CHANNEL_ID_DECESE=PLACEHOLDER_CHANNEL_ID_DECESE

# URL Webhook Discord — pentru script-uri (reset-resurse, alerts)
# Creare: Canal → Edit → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=PLACEHOLDER_DISCORD_WEBHOOK_URL

# ── Cloudflare Tunnel ─────────────────────────────────────────
# Token tunel Cloudflare — Zero Trust → Tunnels → Create tunnel → Docker
# Expune map.serverultau.ro → http://mc:8123 (Dynmap intern)
CLOUDFLARE_TUNNEL_TOKEN=PLACEHOLDER_CLOUDFLARE_TUNNEL_TOKEN

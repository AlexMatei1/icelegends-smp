    set {shop::qty::COBBLESTONE} to 64
    set {shop::qty::IRON_INGOT} to 16
    set {shop::qty::GOLD_INGOT} to 16
    set {shop::qty::DIAMOND} to 1
    set {shop::qty::COAL} to 32
    set {shop::qty::BREAD} to 32
    set {shop::qty::CARROT} to 32
    set {shop::qty::COOKED_BEEF} to 16
    set {shop::qty::COOKED_CHICKEN} to 16
    set {shop::qty::APPLE} to 16
    set {shop::qty::LEATHER} to 16

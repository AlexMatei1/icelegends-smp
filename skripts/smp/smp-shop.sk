# ── Funcție: ia item din inventarul jucătorului ───────────────

function takeByMat(p: player, mat: text, qty: number) :: number:
    if {_mat} is "OAK_LOG":
        set {_have} to amount of oak log in {_p}'s inventory
        if {_have} < {_qty}:
            return {_have}
        remove {_qty} of oak log from {_p}'s inventory
        return -1
    else if {_mat} is "BIRCH_LOG":
        set {_have} to amount of birch log in {_p}'s inventory
        if {_have} < {_qty}:
            return {_have}
        remove {_qty} of birch log from {_p}'s inventory
        return -1

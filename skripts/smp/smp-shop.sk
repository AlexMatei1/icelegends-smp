# ── Funcție: generează lore pentru un item ────────────────────

function buildLore(mat: text) :: texts:
    set {_buy} to {shop::buy::%{_mat}%}
    if {_buy} is not set:
        set {_buy} to 0
    set {_sell} to {shop::sell::%{_mat}%}
    if {_sell} is not set:
        set {_sell} to 0
    set {_qty} to {shop::qty::%{_mat}%}
    if {_qty} is not set:
        set {_qty} to 64
    set {_tb} to {_buy} * {_qty}
    set {_ts} to {_sell} * {_qty}
    set {_l1} to "&7━━━━━━━━━━━━━━━━━━"
    if {_buy} > 0:
        set {_l2} to "&aCumpără &7x%{_qty}%: &e%{_tb}% {@CURRENCY}"
    else:
        set {_l2} to "&7Nu se poate cumpara"
    if {_sell} > 0:
        set {_l3} to "&6Vinde &7x%{_qty}%: &e%{_ts}% {@CURRENCY}"
    else:
        set {_l3} to "&7Nu se poate vinde"
    set {_l4} to "&7━━━━━━━━━━━━━━━━━━"
    set {_l5} to "&bClic stanga &7-> cumpara"
    if {_sell} > 0:
        set {_l6} to "&bClic dreapta &7-> vinde"
        return {_l1} and {_l2} and {_l3} and {_l4} and {_l5} and {_l6}
    return {_l1} and {_l2} and {_l3} and {_l4} and {_l5}

# ── Funcție: detectează material key din item ─────────────────

function getMatKey(t: item) :: text:
    if type of {_t} is oak log:
        return "OAK_LOG"
    else if type of {_t} is birch log:
        return "BIRCH_LOG"
    else if type of {_t} is spruce log:
        return "SPRUCE_LOG"
    else if type of {_t} is stone:
        return "STONE"
    else if type of {_t} is cobblestone:
        return "COBBLESTONE"
    else if type of {_t} is iron ingot:
        return "IRON_INGOT"
    else if type of {_t} is gold ingot:
        return "GOLD_INGOT"
    else if type of {_t} is diamond:
        return "DIAMOND"
    else if type of {_t} is coal:
        return "COAL"
    else if type of {_t} is bread:
        return "BREAD"
    else if type of {_t} is carrot:
        return "CARROT"
    else if type of {_t} is cooked beef:
        return "COOKED_BEEF"
    else if type of {_t} is cooked chicken:
        return "COOKED_CHICKEN"
    else if type of {_t} is apple:
        return "APPLE"
    else if type of {_t} is leather:
        return "LEATHER"
    else if type of {_t} is bone:
        return "BONE"
    else if type of {_t} is string:
        return "STRING"
    else if type of {_t} is blaze rod:
        return "BLAZE_ROD"
    else if type of {_t} is slime ball:
        return "SLIME_BALL"
    else if "%type of {_t}%" is "ender pearl":
        return "ENDER_PEARL"
    else if type of {_t} is wheat seeds:
        return "WHEAT_SEEDS"
    else if type of {_t} is bone meal:
        return "BONE_MEAL"
    else if type of {_t} is sugar cane:
        return "SUGAR_CANE"
    else if type of {_t} is cactus:
        return "CACTUS"
    else if type of {_t} is elytra:
        return "ELYTRA"
    else if type of {_t} is totem of undying:
        return "TOTEM_OF_UNDYING"
    else if type of {_t} is shulker shell:
        return "SHULKER_SHELL"
    else if type of {_t} is name tag:
        return "NAME_TAG"
    return ""

# ── Funcție: construiește item de shop ────────────────────────

function makeShopItem(mat: text, label: text) :: item:
    if {_mat} is "OAK_LOG":
        set {_item} to oak log named {_label}
    else if {_mat} is "BIRCH_LOG":
        set {_item} to birch log named {_label}
    else if {_mat} is "SPRUCE_LOG":
        set {_item} to spruce log named {_label}
    else if {_mat} is "STONE":
        set {_item} to stone named {_label}
    else if {_mat} is "COBBLESTONE":
        set {_item} to cobblestone named {_label}
    else if {_mat} is "IRON_INGOT":
        set {_item} to iron ingot named {_label}
    else if {_mat} is "GOLD_INGOT":
        set {_item} to gold ingot named {_label}
    else if {_mat} is "DIAMOND":
        set {_item} to diamond named {_label}
    else if {_mat} is "COAL":
        set {_item} to coal named {_label}
    else if {_mat} is "BREAD":
        set {_item} to bread named {_label}
    else if {_mat} is "CARROT":
        set {_item} to carrot named {_label}
    else if {_mat} is "COOKED_BEEF":
        set {_item} to cooked beef named {_label}
    else if {_mat} is "COOKED_CHICKEN":
        set {_item} to cooked chicken named {_label}
    else if {_mat} is "APPLE":
        set {_item} to apple named {_label}
    else if {_mat} is "LEATHER":
        set {_item} to leather named {_label}
    else if {_mat} is "BONE":
        set {_item} to bone named {_label}
    else if {_mat} is "STRING":
        set {_item} to string named {_label}
    else if {_mat} is "BLAZE_ROD":
        set {_item} to blaze rod named {_label}
    else if {_mat} is "SLIME_BALL":
        set {_item} to slime ball named {_label}
    else if {_mat} is "ENDER_PEARL":
        set {_item} to ender pearl named {_label}
    else if {_mat} is "WHEAT_SEEDS":
        set {_item} to wheat seeds named {_label}
    else if {_mat} is "BONE_MEAL":
        set {_item} to bone meal named {_label}
    else if {_mat} is "SUGAR_CANE":
        set {_item} to sugar cane named {_label}
    else if {_mat} is "CACTUS":
        set {_item} to cactus named {_label}
    else if {_mat} is "ELYTRA":
        set {_item} to elytra named {_label}
    else if {_mat} is "TOTEM_OF_UNDYING":
        set {_item} to totem of undying named {_label}
    else if {_mat} is "SHULKER_SHELL":
        set {_item} to shulker shell named {_label}
    else if {_mat} is "NAME_TAG":
        set {_item} to name tag named {_label}
    else:
        return air
    set {_lore::*} to buildLore({_mat})
    set lore of {_item} to {_lore::*}
    return {_item}

# ── Funcție: dă item jucătorului din material key ─────────────

function giveByMat(p: player, mat: text, qty: number):

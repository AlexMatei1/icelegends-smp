# ── Meniu principal ───────────────────────────────────────────

function deschideMain(p: player):
    set {_inv} to a new chest inventory with 3 rows named "§6§lSMP Shop [SMP]"
    loop 27 times:
        set slot loop-number - 1 of {_inv} to gray stained glass pane named " "
    set {_r} to iron pickaxe named "&6Resurse"
    set lore of {_r} to "&7Lemn, Piatra, Metale" and "&8-> Click pentru a deschide"
    set slot 10 of {_inv} to {_r}
    set {_h} to bread named "&aHrana"
    set lore of {_h} to "&7Paine, Carne, Fructe" and "&8-> Click pentru a deschide"
    set slot 12 of {_inv} to {_h}
    set {_m} to bone named "&cDrops Mob-uri"
    set lore of {_m} to "&7Piele, Blaze Rod, Perle" and "&8-> Click pentru a deschide"
    set slot 14 of {_inv} to {_m}
    set {_a} to wheat seeds named "&2Agricultura"
    set lore of {_a} to "&7Seminte, Trestie, Cactus" and "&8-> Click pentru a deschide"
    set slot 16 of {_inv} to {_a}
    set {_s} to elytra named "&5Special"
    set lore of {_s} to "&7Elitre, Totem, Shulker Shell" and "&8-> Click pentru a deschide" and "&4Preturi ridicate - end-game"
    set slot 22 of {_inv} to {_s}
    set {shop::%{_p}'s uuid%::page} to "main"
    open {_inv} to {_p}

# ── Meniu Resurse ─────────────────────────────────────────────

function deschideResurse(p: player):
    set {_inv} to a new chest inventory with 6 rows named "§6Resurse [SMP]"
    loop 54 times:
        set slot loop-number - 1 of {_inv} to gray stained glass pane named " "
    set {shop::%{_p}'s uuid%::slot::10} to "OAK_LOG"
    set {shop::%{_p}'s uuid%::slot::11} to "BIRCH_LOG"
    set {shop::%{_p}'s uuid%::slot::12} to "SPRUCE_LOG"
    set {shop::%{_p}'s uuid%::slot::13} to "STONE"
    set {shop::%{_p}'s uuid%::slot::14} to "COBBLESTONE"
    set {shop::%{_p}'s uuid%::slot::19} to "IRON_INGOT"
    set {shop::%{_p}'s uuid%::slot::20} to "GOLD_INGOT"
    set {shop::%{_p}'s uuid%::slot::21} to "DIAMOND"
    set {shop::%{_p}'s uuid%::slot::22} to "COAL"
    set slot 10 of {_inv} to makeShopItem("OAK_LOG", "&fButean de Stejar")
    set slot 11 of {_inv} to makeShopItem("BIRCH_LOG", "&fButean de Mesteacan")
    set slot 12 of {_inv} to makeShopItem("SPRUCE_LOG", "&fButean de Molid")
    set slot 13 of {_inv} to makeShopItem("STONE", "&7Piatra")
    set slot 14 of {_inv} to makeShopItem("COBBLESTONE", "&7Piatra Bruta")
    set slot 19 of {_inv} to makeShopItem("IRON_INGOT", "&fLingou de Fier")
    set slot 20 of {_inv} to makeShopItem("GOLD_INGOT", "&6Lingou de Aur")
    set slot 21 of {_inv} to makeShopItem("DIAMOND", "&bDiamant")
    set slot 22 of {_inv} to makeShopItem("COAL", "&8Carbune")
    set slot 49 of {_inv} to red stained glass pane named "&cInapoi"
    set {shop::%{_p}'s uuid%::page} to "cat"
    open {_inv} to {_p}

# ── Meniu Hrană ───────────────────────────────────────────────

function deschideHrana(p: player):
    set {_inv} to a new chest inventory with 6 rows named "§aHrana [SMP]"
    loop 54 times:
        set slot loop-number - 1 of {_inv} to gray stained glass pane named " "
    set {shop::%{_p}'s uuid%::slot::10} to "BREAD"
    set {shop::%{_p}'s uuid%::slot::11} to "CARROT"
    set {shop::%{_p}'s uuid%::slot::12} to "COOKED_BEEF"
    set {shop::%{_p}'s uuid%::slot::13} to "COOKED_CHICKEN"
    set {shop::%{_p}'s uuid%::slot::14} to "APPLE"
    set slot 10 of {_inv} to makeShopItem("BREAD", "&fPaine")
    set slot 11 of {_inv} to makeShopItem("CARROT", "&6Morcov")
    set slot 12 of {_inv} to makeShopItem("COOKED_BEEF", "&cBiftek Fiert")
    set slot 13 of {_inv} to makeShopItem("COOKED_CHICKEN", "&fPui Fiert")
    set slot 14 of {_inv} to makeShopItem("APPLE", "&cMar")
    set slot 49 of {_inv} to red stained glass pane named "&cInapoi"
    set {shop::%{_p}'s uuid%::page} to "cat"
    open {_inv} to {_p}

# ── Meniu Mob Drops ───────────────────────────────────────────

function deschideMobDrops(p: player):
    set {_inv} to a new chest inventory with 6 rows named "§cDrops Mob [SMP]"
    loop 54 times:
        set slot loop-number - 1 of {_inv} to gray stained glass pane named " "
    set {shop::%{_p}'s uuid%::slot::10} to "LEATHER"
    set {shop::%{_p}'s uuid%::slot::11} to "BONE"
    set {shop::%{_p}'s uuid%::slot::12} to "STRING"
    set {shop::%{_p}'s uuid%::slot::13} to "BLAZE_ROD"
    set {shop::%{_p}'s uuid%::slot::14} to "SLIME_BALL"
    set {shop::%{_p}'s uuid%::slot::19} to "ENDER_PEARL"
    set slot 10 of {_inv} to makeShopItem("LEATHER", "&6Piele")
    set slot 11 of {_inv} to makeShopItem("BONE", "&fOs")
    set slot 12 of {_inv} to makeShopItem("STRING", "&fFir")
    set slot 13 of {_inv} to makeShopItem("BLAZE_ROD", "&eBat de Blaze")
    set slot 14 of {_inv} to makeShopItem("SLIME_BALL", "&aBila de Slime")
    set slot 19 of {_inv} to makeShopItem("ENDER_PEARL", "&5Perla de Ender")
    set slot 49 of {_inv} to red stained glass pane named "&cInapoi"
    set {shop::%{_p}'s uuid%::page} to "cat"
    open {_inv} to {_p}

# ── Meniu Agricultură ─────────────────────────────────────────

function deschideAgricultura(p: player):
    set {_inv} to a new chest inventory with 6 rows named "§2Agricultura [SMP]"

    set slot 11 of {_inv} to makeShopItem("BONE_MEAL", "&fFaina de Os")
    set slot 12 of {_inv} to makeShopItem("SUGAR_CANE", "&aTrestie de Zahar")
    set slot 13 of {_inv} to makeShopItem("CACTUS", "&2Cactus")

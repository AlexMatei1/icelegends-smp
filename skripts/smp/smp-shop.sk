# ============================================================
# SMP Shop — Înlocuire custom pentru ShopGUI+
# Comenzi: /shop
# Economie: Vault (EssentialsX)
# ============================================================

options:
    CURRENCY: coins

# ── Inițializare prețuri la încărcare script ──────────────────

on load:

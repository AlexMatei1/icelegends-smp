    set {shop::sell::COAL} to 1
    set {shop::sell::BREAD} to 2
    set {shop::sell::CARROT} to 1
    set {shop::sell::COOKED_BEEF} to 4
    set {shop::sell::COOKED_CHICKEN} to 3
    set {shop::sell::APPLE} to 1
    set {shop::sell::LEATHER} to 3
    set {shop::sell::BONE} to 2
    set {shop::sell::STRING} to 2
    set {shop::sell::BLAZE_ROD} to 14
    set {shop::sell::SLIME_BALL} to 5
    set {shop::sell::ENDER_PEARL} to 10

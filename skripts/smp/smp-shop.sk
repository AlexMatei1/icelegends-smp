# ── Meniu Special ─────────────────────────────────────────────

function deschideSpecial(p: player):
    set {_inv} to a new chest inventory with 6 rows named "§5Special [SMP]"
    loop 54 times:
        set slot loop-number - 1 of {_inv} to gray stained glass pane named " "
    set {shop::%{_p}'s uuid%::slot::10} to "ELYTRA"
    set {shop::%{_p}'s uuid%::slot::11} to "TOTEM_OF_UNDYING"
    set {shop::%{_p}'s uuid%::slot::12} to "SHULKER_SHELL"
    set {shop::%{_p}'s uuid%::slot::13} to "NAME_TAG"
    set slot 10 of {_inv} to makeShopItem("ELYTRA", "&dElitre")
    set slot 11 of {_inv} to makeShopItem("TOTEM_OF_UNDYING", "&6Totem al Nemuririi")
    set slot 12 of {_inv} to makeShopItem("SHULKER_SHELL", "&5Cochilie Shulker")
    set slot 13 of {_inv} to makeShopItem("NAME_TAG", "&fEticheta Nume")
    set slot 49 of {_inv} to red stained glass pane named "&cInapoi"
    set {shop::%{_p}'s uuid%::page} to "cat"
    open {_inv} to {_p}

# ── Comanda /shop ─────────────────────────────────────────────

command /shop [<text>]:
    permission: smp.shop
    permission message: "&cNu ai permisiunea de a folosi shop-ul."
    trigger:
        if arg-1 is "resurse":
            deschideResurse(player)
        else if arg-1 is "hrana":
            deschideHrana(player)
        else if arg-1 is "mobdrops":
            deschideMobDrops(player)
        else if arg-1 is "agricultura":
            deschideAgricultura(player)
        else if arg-1 is "special":
            deschideSpecial(player)
        else:
            deschideMain(player)

# ── Handler click inventar ────────────────────────────────────

on inventory click:
    if name of event-inventory contains "[SMP]":
        cancel event
        if name of event-inventory is "§6§lSMP Shop [SMP]":
            if event-slot is 10:
                deschideResurse(player)
            else if event-slot is 12:
                deschideHrana(player)
            else if event-slot is 14:
                deschideMobDrops(player)
            else if event-slot is 16:
                deschideAgricultura(player)
            else if event-slot is 22:
                deschideSpecial(player)
            stop
        if event-slot is 49:
            deschideMain(player)
            stop
        if event-item is not set:
            stop
        if event-item is air:
            stop
        if type of event-item is gray stained glass pane:
            stop
        if type of event-item is red stained glass pane:
            stop
        set {_mat} to getMatKey(event-item)
        if {_mat} is "":
            stop
        set {_buy} to {shop::buy::%{_mat}%}
        if {_buy} is not set:
            set {_buy} to 0
        set {_sell} to {shop::sell::%{_mat}%}
        if {_sell} is not set:
            set {_sell} to 0
        set {_qty} to {shop::qty::%{_mat}%}
        if {_qty} is not set:
            set {_qty} to 64
        set {_ct} to "%event-clicktype%"
        set {_buying} to false
        set {_selling} to false
        if {_ct} contains "left":
            set {_buying} to true
        else if {_ct} contains "right":
            set {_selling} to true
        if {_buying} is true:
            if {_buy} is 0:
                send "&cAcest item nu se poate cumpara." to player
                stop
            set {_cost} to {_buy} * {_qty}
            if player's balance < {_cost}:
                send "&cNu ai destui bani! Cost: &e%{_cost}% coins&c, sold: &e%player's balance% coins&c." to player
                stop
            remove {_cost} from player's balance
            giveByMat(player, {_mat}, {_qty})
            send "&a+ Cumparat &f%{_qty}%x %{_mat}% &apentru &e%{_cost}% coins&a. &7Sold: &e%floor(player's balance)% coins" to player
        if {_selling} is true:
            if {_sell} is 0:
                send "&cAcest item nu se poate vinde in shop." to player
                stop
            set {_have} to takeByMat(player, {_mat}, {_qty})
            if {_have} is not -1:
                send "&cNu ai destule! Ai &e%{_have}%x&c, nevoie de &e%{_qty}%x&c." to player
                stop
            set {_earn} to {_sell} * {_qty}
            add {_earn} to player's balance
            send "&a+ Vandut &f%{_qty}%x %{_mat}% &apentru &e%{_earn}% coins&a. &7Sold: &e%floor(player's balance)% coins" to player

# ── Curata starea la inchidere inventar ───────────────────────

on inventory close:
    if name of event-inventory contains "[SMP]":
        delete {shop::%player's uuid%::page}
        delete {shop::%player's uuid%::slot::*}

# ── Comanda /sell — vinde item din mana ──────────────────────

command /sell [<number>]:
    permission: smp.shop
    permission message: "&cNu ai permisiunea."
    trigger:
        set {_item} to player's held item
        if {_item} is air:
            send "&cTine un item in mana pentru a-l vinde." to player
            stop
        set {_mat} to getMatKey({_item})
        if {_mat} is "":
            send "&cAcest item nu se poate vinde in shop. Verifica &e/shop&c." to player
            stop
        set {_sell} to {shop::sell::%{_mat}%}
        if {_sell} is not set:
            send "&cAcest item nu se poate vinde." to player
            stop
        set {_maxQty} to {shop::qty::%{_mat}%}
        if {_maxQty} is not set:
            set {_maxQty} to 64
        set {_qty} to arg-1
        if arg-1 is not set:
            set {_qty} to {_maxQty}
        if {_qty} > {_maxQty}:
            set {_qty} to {_maxQty}
        set {_have} to takeByMat(player, {_mat}, {_qty})
        if {_have} is not -1:
            send "&cNu ai destule! Ai &e%{_have}%x&c, vrei sa vinzi &e%{_qty}%x&c." to player
            stop
        set {_earn} to {_sell} * {_qty}
        add {_earn} to player's balance
        send "&a+ Vandut &f%{_qty}%x %{_mat}% &apentru &e%{_earn}% coins&a. Sold: &e%player's balance% coins&a." to player
